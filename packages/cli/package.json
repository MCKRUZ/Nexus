{
  "name": "@nexus/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus CLI — nexus init, nexus project, nexus sync",
  "main": "./dist/index.js",
  "bin": {
    "nexus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose src/**/*.unit.test.ts",
    "test:integration": "vitest run --reporter=verbose src/**/*.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@nexus/core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
