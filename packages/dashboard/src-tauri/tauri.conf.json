{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexus",
  "version": "0.1.0",
  "identifier": "dev.nexus.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build && pnpm compile:server",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nexus",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/nexus-server"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "Nexus",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "shortDescription": "Cross-project intelligence layer for Claude Code",
    "longDescription": "Nexus — local-first intelligence layer that observes, learns, and coordinates across all Claude Code sessions."
  }
}
